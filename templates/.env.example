# Environment variables for CLAUDE.md.template substitution.
# Copy to .env and fill with your real values.
# .env should be in .gitignore — never commit real values.

# ─── Project identity ────────────────────────────────────────────────
PROJECT_NAME=my-project
PROJECT_DESCRIPTION_ONE_LINE="A short, one-line description of what this project does."
ARCHITECTURE_ONE_LINE="Backend in X, frontend in Y, deployed to Z."
REPO_LAYOUT_ONE_LINE="apps/ for runnable code, packages/ for libs, infrastructure/ for deploy."

# ─── Deploy / infrastructure ─────────────────────────────────────────
DEPLOY_SERVER_IP=10.0.0.1
DEPLOY_SSH_HOST=my-docker-vm
DEPLOY_SCRIPT=./infrastructure/deploy/deploy.sh

# ─── Backup ──────────────────────────────────────────────────────────
BACKUP_REPO=sftp:storagebox:my-restic
BACKUP_PASSWORD_FILE=/root/.restic-password

# ─── Protected paths ─────────────────────────────────────────────────
# Where original design source lives (scrapes, exports, references).
DESIGN_SOURCE_DIR=design-source
# Where external design templates live (Figma exports, theme starters).
TEMPLATE_DIR=design-templates

# ─── Verification commands ───────────────────────────────────────────
# Replace with your stack's typical verification chain.
# Example values shown below — comment out / replace as needed.
#
# Backend (FastAPI / Python):
#   cd backend && pytest --maxfail=5
#
# Frontend (React / Vite / TypeScript):
#   cd frontend && npm test -- --run
#   cd frontend && npx tsc --noEmit
#   cd frontend && npm run build
#
# Or your equivalent.
VERIFICATION_COMMANDS_FOR_YOUR_STACK="(see comments above — replace with your stack)"
